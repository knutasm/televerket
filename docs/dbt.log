{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"e36d8cda-b91e-4ece-a6fc-177d73d6cd1f\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from \"televerket\".\"main\".\"dbt_run_results\" run_results\n      join \"televerket\".\"main\".\"dbt_models\" models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocations.invocation_id,\n      invocations.command,\n      invocations.selected,\n      invocations.full_refresh,\n      \n        invocations.job_url,\n      \n      invocations.job_name,\n      invocations.job_id,\n      invocations.orchestrator\n    from \"televerket\".\"main\".\"dbt_invocations\" invocations\n    join latest_models_invocations on invocations.invocation_id = latest_models_invocations.invocation_id\n  \n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "e36d8cda-b91e-4ece-a6fc-177d73d6cd1f", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"e36d8cda-b91e-4ece-a6fc-177d73d6cd1f\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from \"televerket\".\"main\".\"dbt_run_results\" run_results\n      join \"televerket\".\"main\".\"dbt_models\" models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocations.invocation_id,\n      invocations.command,\n      invocations.selected,\n      invocations.full_refresh,\n      \n        invocations.job_url,\n      \n      invocations.job_name,\n      invocations.job_id,\n      invocations.orchestrator\n    from \"televerket\".\"main\".\"dbt_invocations\" invocations\n    join latest_models_invocations on invocations.invocation_id = latest_models_invocations.invocation_id\n  \n\n  ", "name": "SQLQuery", "pid": 80439, "thread": "MainThread", "ts": "2026-05-25T19:48:28.522707Z"}}
