chema_name,\n                  identifier as table_name,\n                  owner as owners,\n                  tags,\n                  package_name,\n                  description,\n                  original_path as full_path,\n                  meta\n                from \"televerket\".\"main\".\"dbt_sources\"\n              )\n\n            select * from dbt_artifacts_sources\n        \n\n  ", "name": "SQLQuery", "pid": 80439, "thread": "MainThread", "ts": "2026-05-25T19:48:21.942949Z"}}
