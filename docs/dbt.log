{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"3847074b-4bf6-44c1-a678-9dcbfa575329\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n        with dbt_artifacts_seeds as (\n          select\n            name,\n            unique_id,\n            database_name,\n            schema_name,\n            case when alias is not null then alias\n            else name end as table_name,\n            owner as owners,\n            tags,\n            package_name,\n            description,\n            original_path as full_path\n          from \"televerket\".\"main\".\"dbt_seeds\"\n        )\n\n        select * from dbt_artifacts_seeds\n  \n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "3847074b-4bf6-44c1-a678-9dcbfa575329", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"3847074b-4bf6-44c1-a678-9dcbfa575329\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n        with dbt_artifacts_seeds as (\n          select\n            name,\n            unique_id,\n            database_name,\n            schema_name,\n            case when alias is not null then alias\n            else name end as table_name,\n            owner as owners,\n            tags,\n            