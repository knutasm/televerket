: "televerket", "identifier": "stg__network_incidents", "schema": "main"}, {"database": "televerket", "identifier": "stg__network_service_activations", "schema": "main"}], "schema": "main"}, "info": {"category": "", "code": "E014", "extra": {}, "invocation_id": "560256d2-e00c-45c0-9dc8-0e564a58c990", "level": "debug", "msg": "While listing relations in database=televerket, schema=main, found: alerts_anomaly_detection, alerts_dbt_models, alerts_dbt_source_freshness, alerts_dbt_tests, alerts_schema_changes, anomaly_threshold_sensitivity, billing_invoices, billing_payments, catalog_products, crm_contracts, crm_customers, data_monitoring_metrics, dbt_artifacts_hashes, dbt_columns, dbt_exposures, dbt_groups, dbt_invocations, dbt_metrics, dbt_models, dbt_run_results, dbt_seeds, dbt_snapshots, dbt_sources, dbt_source_freshness_results, dbt_tests, elementary_test_results, int__billing_invoice_settlement, int__customers_activations, int__customers_enriched, int__network_incidents_enriched, job_run_results, metadata, metrics_anomaly_score, model_run_results, monitors_runs, network_incidents, network_service_activations, schema_columns_snapshot, seed_run_results, snapshot_run_results, test_result_rows, mart_customer_360, std__crm_customers, stg__billing_invoices, stg__billing_payments, stg__catalog_products, stg__crm_contracts, stg__crm_customers, stg__network_incidents, stg__network_service_activations", "name": "ListRelations", "pid": 80439, "thread": "MainThread", "ts": "2026-05-25T19:48:25.931526Z"}}
