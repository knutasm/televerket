{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"0a937223-75ee-4d21-a08c-86e64c570f98\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n        select\n            unique_id,\n            null as depends_on_nodes,\n            null as materialization,\n            'seed' as type\n        from \"televerket\".\"main\".\"dbt_seeds\"\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            materialization,\n            'snapshot' as type\n        from \"televerket\".\"main\".\"dbt_snapshots\"\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            materialization,\n            'model' as type\n        from \"televerket\".\"main\".\"dbt_models\"\n        \n            where package_name != 'elementary'\n        \n        union all\n        select\n            unique_id,\n            null as depends_on_nodes,\n            null as materialization,\n            'source' as type\n        from \"televerket\".\"main\".\"dbt_sources\"\n        union all\n        select\n            unique_id,\n            depends_on_nodes,\n            null as materialization,\n            'exposure' as type\n        from \"televerket\".\"main\".\"dbt_exposures\"\n    \n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "0a937223-75ee-4d21-a08c-86e64c570f98", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n