{"data": {"msg": "Elementary: --ELEMENTARY-MACRO-OUTPUT-START--[{\"unique_id\": \"model.televerket.stg__billing_invoices\", \"invocation_id\": \"4c0747ec-c3a3-4747-9f2d-c9f7011c3ec5\", \"name\": \"stg__billing_invoices\", \"schema\": \"main\", \"status\": \"success\", \"execution_time\": 0, \"full_refresh\": false, \"materialization\": \"view\", \"compiled_code\": \"with source as (\\n    select * from \\\"televerket\\\".\\\"billing\\\".\\\"invoices\\\"\\n),\\n\\ncasts as (\\n    select\\n        invoiceid as invoice_id,\\n        customer_id,\\n        \\n    strptime(invoice_date, '%Y%m%d')::date\\n as invoice_date,\\n        \\n    strptime(due_date, '%Y%m%d')::date\\n     as due_date,\\n        try_cast(amount_eur as decimal(10, 2)) as amount_eur,\\n        status\\n    from source\\n)\\n\\nselect\\n    invoice_id,\\n    customer_id,\\n    invoice_date,\\n    due_date,\\n    amount_eur,\\n    status\\nfrom casts\", \"generated_at\": \"2026-05-25 19:44:31\"}, {\"unique_id\": \"model.televerket.stg__catalog_products\", \"invocation_id\": \"4c0747ec-c3a3-4747-9f2d-c9f7011c3ec5\", \"name\": \"stg__catalog_products\", \"schema\": \"main\", \"status\": \"success\", \"execution_time\": 0, \"full_refresh\": false, \"materialization\": \"view\", \"compiled_code\": \"with source as (\\n    select * from \\\"televerket\\\".\\\"catalog\\\".\\\"products\\\"\\n),\\n\\ncasts as (\\n    select\\n        product_code,\\n        product_name,\\n        category,\\n        monthly_fee_eur,\\n        data_gb,\\n        voice_min,\\n        valid_from::date as valid_from,\\n        valid_to::date as valid_to\\n    from source\\n)\\n\\nselect\\n    product_code,\\n    product_name,\\n    category,\\n    monthly_fee_eur,\\n    data_gb,\\n    voice_min,\\n    valid_from,\\n    valid_to\\nfrom casts\", \"generated_at\": \"2026-05-25 19:44:31\"}, {\"unique_id\": \"model.televerket.stg__billing_payments\", \"invocation_id\": \"4c0747ec-c3a3-4747-9f2d-c9f7011c3ec5\", \"name\": \"stg__billi