{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"df429128-9c49-4a8f-ba97-4583423ec785\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        run_results.unique_id,\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from \"televerket\".\"main\".\"dbt_run_results\" run_results\n      join \"televerket\".\"main\".\"dbt_models\" models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_run_results as (\n      select unique_id, invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select unique_id, invocation_id from latest_run_results\n  \n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "df429128-9c49-4a8f-ba97-4583423ec785", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"df429128-9c49-4a8f-ba97-4583423ec785\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        run_results.unique_id,\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from \"televerket\".\"main\".\"dbt_run_results\" run_results\n      join \"televerket\".\"main\".\"dbt_models\" models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_run_results as (\n      select unique_id, invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select unique_id, invocation_id from latest_run_results\n  \n\n  ", "name": "SQLQuery", "pid": 80439, "thread": "MainThread", "ts": "2026-05-25T19:48:27.837458Z"}}
